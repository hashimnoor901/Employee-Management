<div class="container" >  
<% if @employee.errors.any? %>

        <h2 class="text-danger">Please fix the following errors:</h2>
        <% @employee.errors.full_messages.each do |message| %>
          <%# <div class="alert alert-danger"> %>
            <p class="text-danger" ><%= message %></p>
          <%# </div> %>
        <%end%>
        </div>
        <%end%>
      <%= form_with model:@employee do |form| %>
        <div class = "row   " >
            <div class="col-md-3 my-2"> 
              <div class="form-group">
                <%= form.label :first_name %>
                <%= form.text_field :first_name, class: "form-control" %>
              </div>
            </div>
            <div class="col-md-3 my-2">
              <div class="form-group">
                <%= form.label :middle_name %>
                <%= form.text_field :middle_name, class: "form-control" %>
              </div>
            </div>
            <div class="col-md-3 my-2">
              <div class="form-group">
                <%= form.label :last_name %>
                <%= form.text_field :last_name, class: "form-control" %>
              </div>
            </div>
            <div class="col-md-3 my-2">
              <div class="form-group">
                <%= form.label :personal_email %>
                <%= form.text_field :personal_email, class: "form-control" %>
              </div>
            </div>
            <div class="col-md-3 my-2">
              <div class="form-group">
                <%= form.label :city %>
                <%= form.text_field :city, class: "form-control" %>
              </div>
            </div>
            <div class="col-md-3 my-2">
              <div class="form-group">
                <%= form.label :state %>
                <%= form.text_field :state, class: "form-control" %>
              </div>
            </div>
            <div class="col-md-3 my-2">
              <div class="form-group">
                <%= form.label :country %>
                <%= form.text_field :country, class: "form-control" %>
              </div>
            </div>
            <div class="col-md-3 my-2">
              <div class="form-group">
                <%= form.label :pincode %>
                <%= form.text_field :pincode, class: "form-control" %>
              </div>
            </div>
            <div class="col-md-6 my-2">
              <div class="form-group">
                <%= form.label :adress_line_1 %>
                <%= form.text_field :adress_line_1, class: "form-control" %>
              </div>
            </div>
            <div class="col-md-6 my-2">
              <div class="form-group">
                <%= form.label :adress_line_2 %>
                <%= form.text_field :adress_line_2, class: "form-control" %>
              </div>
            </div>
            
            <%= form.submit class:'btn btn-primary col-md-2 my-2 mx-2 ' %>
            <%= link_to 'Back To Employees' , employees_path, class:'btn btn-outline-primary btn-lg ' %>
        </div>
        <%end%>
        </div>