<div class="container  mt-5">
  <%= link_to 'Create new Employee', new_employee_path, class:"btn btn-primary" %>
  <h1>Employees List</h1>
  <%= flash[:notice] %>
  <table class="table table-striped table-bordered">
    <thead>
      <tr>
        <th>ID</th>
        <th>Name</th>
        <th>Email</th>
        <th>City</th>
        <th>Country</th>
        <th>State</th>
        <th>Pincode</th>
        <th>Address 1</th>
        <th>Address 2</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @employees.each do |employee| %>
        <tr>
          <td><%= employee.id %></td>
          <td><%= employee.first_name %> <%= employee.last_name %> </td>
          <td><%= employee.personal_email %></td>
          <td><%= employee.city %></td>
          <td><%= employee.country %></td>
          <td><%= employee.state %></td>
          <td><%= employee.pincode %></td>
          <td><%= employee.adress_line_1 %></td>
          <td><%= employee.adress_line_2 %></td>
          <td> 
            <div class="dropdown">
              <button class="btn btn-primary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                Actions
              </button>
              <ul class="dropdown-menu">
                <li><%= link_to "Edit", edit_employee_path(employee), class:"dropdown-item" %>
                </li>
                <li><%= link_to "Show", employee_path(employee), class:"dropdown-item" %>
                </li>
                <li><%= link_to "Delete", employee_path(employee), class:"dropdown-item" , method: :delete , data:{confirm:"Are you sure to delete this employee"} %>
                </li>
              </ul>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>