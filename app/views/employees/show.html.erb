<div class="card container col-md-8 offset-md-2 mt-5">
  <div class="card-body">
    <h2 class="text-center mb-4">Employee Details</h2>
    
    <div class="row">
      <!-- Personal Information -->
      <div class="col-md-6">
        <h4 class="text-start mb-3">Personal Information</h4>
        <p><strong>First Name:</strong> <%= @employee.first_name %></p>
        <p><strong>Last Name:</strong> <%= @employee.last_name %></p>
        <p><strong>Middle Name:</strong> <%= @employee.middle_name %></p>
        <p><strong>Personal Email:</strong> <%= @employee.personal_email %></p>
      </div>

      <!-- Address Information -->
      <div class="col-md-6">
        <h4 class="text-start mb-3">Address Information</h4>
        <p><strong>City:</strong> <%= @employee.city %></p>
        <p><strong>State:</strong> <%= @employee.state %></p>
        <p><strong>Country:</strong> <%= @employee.country %></p>
        <p><strong>Pincode:</strong> <%= @employee.pincode %></p>
        <p><strong>Address Line 1:</strong> <%= @employee.adress_line_1 %></p>
        <p><strong>Address Line 2:</strong> <%= @employee.adress_line_2 %></p>
      </div>
    </div>

    <!-- Buttons -->
    <div class="text-center mt-4">
      <%= link_to 'Edit Employee', edit_employee_path(@employee), class: 'btn btn-primary me-2' %>
      <%= link_to 'Back to Employees List', employees_path, class: 'btn btn-secondary' %>
    </div>
  </div>
</div>
